{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "watcher",
  "version": "3.0.0",
  "identifier": "com.tacticaldeux.watcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/64x64.png",
      "icons/32x32.png",
      "icons/16x16.png"
    ],
    "resources": [
      "icons/**/*",
      "utils/**/*"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
